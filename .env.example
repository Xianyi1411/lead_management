# Copy to .env and fill in. .env is gitignored (Blueprint §9: secrets never committed).

# --- Database ---
# Dev / demo default: local SQLite file (offline-resilient, no server needed).
DATABASE_URL="file:./dev.db"
# Production (ADR-0001): point at Neon PostgreSQL and switch the provider in
# prisma/schema.prisma to "postgresql", e.g.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# --- Auth ---
# Secret used to sign session cookies. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-me-to-a-long-random-string"
