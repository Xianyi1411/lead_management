// Authoritative source for the ERD (Blueprint §6). Keep BLUEPRINT.md in sync.
//
// Provider is SQLite for dev/demo resilience (file-based, offline). For production
// (ADR-0001) switch provider to "postgresql" and point DATABASE_URL at Neon.
// Status/Role/Source/Type are stored as String (not native DB enums) so the schema
// is portable across SQLite and Postgres; validity is enforced in app code via the
// TypeScript unions and the pure modules in lib/ (transitions, permissions).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("SALES_REP") // Role: ADMIN | MANAGER | SALES_REP
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  assignedLeads Lead[]     @relation("AssignedTo")
  createdLeads  Lead[]     @relation("CreatedBy")
  activities    Activity[]
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String?
  company      String?
  source       String   @default("OTHER") // LeadSource
  status       String   @default("NEW")   // LeadStatus
  dealValue    Int      @default(0)        // RM, whole ringgit (SQLite has no Decimal; switch to Decimal when moving to Postgres)
  notes        String?
  // Qualification facts captured at intake (BANT-style) — they feed lib/scoring.ts
  // and become training features for a future win-prediction model (ADR-0003).
  budgetStatus String   @default("UNKNOWN") // BudgetStatus: CONFIRMED | LIKELY | UNKNOWN | NONE
  authority    String   @default("UNKNOWN") // Authority: DECISION_MAKER | INFLUENCER | UNKNOWN
  timeline     String   @default("UNKNOWN") // Timeline: IMMEDIATE | THIS_QUARTER | THIS_YEAR | UNKNOWN
  // Optional exact figures behind the bands (Blueprint §14.8): the customer's
  // stated budget in RM, and the expected purchase date. When the date is set,
  // `timeline` is derived from it server-side; the band is never asked twice.
  budgetAmount    Int?
  expectedCloseAt DateTime?
  // Working-the-lead fields
  nextFollowUpAt DateTime? // when the next touch is due; overdue = attention needed
  lostReason     String?   // LostReason — set when status becomes LOST, cleared on reopen
  assignedToId String?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTo User?      @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User       @relation("CreatedBy", fields: [createdById], references: [id])
  activities Activity[]

  @@index([status])
  @@index([assignedToId])
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  type      String // ActivityType: WHATSAPP_CONTACT | STATUS_CHANGE | ASSIGNMENT | NOTE | CREATED | FOLLOW_UP
  detail    String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([leadId])
}

// Team-added lead sources beyond the six built-ins (Blueprint §14.7).
// Lead.source stores either a built-in code ("WEBSITE") or a custom name
// ("Google Ads") — validity is enforced in the server actions against the
// LeadSource union plus this table.
model CustomSource {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// Editable WhatsApp message templates (Blueprint §14.9). Managers/Admins manage
// them on /templates; each template declares which Roles may use it (CSV of
// Role values — SQLite has no arrays), so the WhatsApp panel shows each user
// only their templates. Placeholders: {leadName} {company} {repName}.
model MessageTemplate {
  id        String   @id @default(cuid())
  label     String   @unique
  body      String
  roles     String // CSV of Role values, e.g. "ADMIN,MANAGER,SALES_REP"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
